{
  "name": "@sovereign/worker-browser",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @sovereign/worker-browser^... build && tsc",
