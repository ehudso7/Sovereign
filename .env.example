# Application
NODE_ENV=development
LOG_LEVEL=debug
AUTH_MODE=local

# Database
DATABASE_URL=postgresql://sovereign:sovereign_dev@localhost:5432/sovereign

# Redis
REDIS_URL=redis://localhost:6379

# Auth (WorkOS)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Web
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WORKOS_CLIENT_ID=

# Security
# Comma-separated list of allowed web origins for cross-origin browser requests.
# Leave unset in local dev to allow localhost workflows automatically.
CORS_ORIGINS=

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=sovereign

# Object Storage (MinIO for local dev)
S3_BUCKET=sovereign-dev
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=sovereign
S3_SECRET_ACCESS_KEY=sovereign_dev

# OpenAI
OPENAI_API_KEY=

# Credential Encryption
SOVEREIGN_SECRET_KEY=change-me-to-a-real-secret-key-at-least-32-chars

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
